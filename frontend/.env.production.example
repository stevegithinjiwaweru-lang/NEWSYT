# ============================================================
# EASYBOX FRONTEND - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.production and fill in with your values
# ============================================================

# API_URL: Your backend API endpoint
# For TrueHost, this should be your backend domain
# Example: https://api.your-domain.com
VITE_API_URL=https://api.your-domain.com

# SOCKET_URL: WebSocket connection endpoint (same as API_URL)
# Used for real-time updates
VITE_SOCKET_URL=https://api.your-domain.com
