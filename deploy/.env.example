# ─────────────────────────────────────────────────────────────────────────────
# NEWSYT deploy/.env — production secrets.
# Copy to deploy/.env and fill values. NEVER commit a populated .env.
# Validated by backend/src/config/env.ts (zod) at boot.
# ─────────────────────────────────────────────────────────────────────────────

# Public origins — used by the frontend build (VITE_API_URL) and by the API's
# CORS allow-list. Two subdomains, one droplet IP.
PUBLIC_API_BASE_URL=https://api.dispatch.gumza.ke
ALLOWED_ORIGINS=https://dispatch.gumza.ke

# Postgres — compose-internal; never exposed to the host.
POSTGRES_DB=newsyt
POSTGRES_USER=newsyt
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# JWT — internal dashboard/rider auth. Both must be ≥32 chars and DIFFERENT.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-a-32-plus-char-random-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-32-plus-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# External API — pepper applied to API-key hashing. ≥32 chars. Master secret.
API_KEY_PEPPER=replace-me-with-a-32-plus-char-pepper-value

# Outbound webhook delivery (Phase 1)
WEBHOOK_MAX_ATTEMPTS=10
WEBHOOK_BASE_BACKOFF_MS=5000

# External API rate limit (per API key, sliding window)
EXTERNAL_RATE_LIMIT_WINDOW_MS=60000
EXTERNAL_RATE_LIMIT_MAX=60

# Customer-facing tracking page (base URL — dispatch id appended)
EXTERNAL_TRACKING_BASE_URL=https://dispatch.gumza.ke/tracking

# Phase 4 — fallback cancellation fee when drop-off isn't inside a Phase 3 zone.
CANCEL_FEE_FALLBACK_AMOUNT=200
CANCEL_FEE_FALLBACK_CURRENCY=KES

# Logging
LOG_LEVEL=info

# Uploads (POD images, CSV imports). Backed by the uploads-data named volume.
UPLOADS_DIR=/usr/src/app/uploads
