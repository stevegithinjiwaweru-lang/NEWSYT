# ============================================================
# EASYBOX BACKEND - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in with your actual values
# NEVER commit your .env file to version control
# ============================================================

# ============================================================
# 1. DATABASE CONFIGURATION (REQUIRED)
# ============================================================
# For TrueHost cPanel shared hosting:
# - Hostname: usually localhost or 127.0.0.1
# - Port: usually 5432
# - Database: created from cPanel > PostgreSQL Databases
# - User: created from cPanel > PostgreSQL Users
# - Password: set when creating the PostgreSQL user
#
# Format: postgresql://username:password@hostname:port/database
# Example: postgresql://easybox_user:MySecurePass123@localhost:5432/easybox_db
DATABASE_URL=postgresql://username:password@localhost:5432/easybox_db

# ============================================================
# 2. SERVER CONFIGURATION
# ============================================================
# PORT: The port your cPanel Node.js app is configured to use
# In cPanel, this is set in "Setup Node.js App"
# Common ports: 3000, 4000, 5000, 8000 (avoid privileged ports < 1024)
PORT=4000

# NODE_ENV: Must be 'production' for optimal performance
NODE_ENV=production

# ============================================================
# 3. FILE UPLOADS CONFIGURATION
# ============================================================
# UPLOADS_DIR: Path where CSV files and proof-of-delivery images are stored
# Use relative path: will be created relative to application root
# For cPanel, use 'uploads' (relative path in home directory)
UPLOADS_DIR=uploads

# ============================================================
# 4. AUTHENTICATION & SECURITY (REQUIRED - GENERATE NEW VALUES!)
# ============================================================
# JWT_SECRET: Used to sign authentication tokens
# REFRESH_TOKEN_SECRET: Used to sign refresh tokens
# 
# Generate secure secrets using:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 
# IMPORTANT: Use DIFFERENT values for each secret
# NEVER use the default/example values in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-change-this-in-production

# ============================================================
# 5. CORS & FRONTEND CONFIGURATION (REQUIRED)
# ============================================================
# FRONTEND_URL: Your frontend/dashboard domain(s)
# This is used for CORS (Cross-Origin Resource Sharing)
# Format: https://your-domain.com or https://admin.your-domain.com
# Multiple domains: https://admin.your-domain.com,https://app.your-domain.com
# 
# For cPanel, use your actual domain name:
FRONTEND_URL=https://admin.your-domain.com

# ============================================================
# 6. EASYBOX INTEGRATION (OPTIONAL)
# ============================================================
# If integrating with Easybox logistics API:
EASYBOX_API_KEY=your-easybox-api-key-if-using-integration
EASYBOX_WEBHOOK_SECRET=your-easybox-webhook-secret-min-32-chars

# ============================================================
# 7. LOGGING CONFIGURATION
# ============================================================
# LOG_LEVEL: info, warn, error, debug
# Recommended: 'info' for production
LOG_LEVEL=info

# ============================================================
# IMPORTANT NOTES FOR TRUEHOST cPANEL:
# ============================================================
# 1. DATABASE:
#    - PostgreSQL must be installed and running on TrueHost
#    - Create database and user from cPanel > PostgreSQL
#    - Use localhost or 127.0.0.1 (not external IP)
#
# 2. PORTS:
#    - Use unprivileged ports (1024-65535)
#    - cPanel assigns the port automatically
#    - Do NOT use ports < 1024 (requires root access)
#
# 3. UPLOADS:
#    - Use relative paths: 'uploads' or './uploads'
#    - Directory will be created automatically on first run
#    - Ensure it's writable by the Node.js process
#
# 4. SECRETS:
#    - CHANGE all default secrets before deploying
#    - Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    - Store securely - never commit to git
#
# 5. DOMAIN:
#    - Update FRONTEND_URL with your actual domain
#    - CORS will only allow requests from this domain
#    - For multiple domains, separate with commas
#
# 6. REDIS:
#    - Redis is optional for this deployment
#    - If not available, the app uses in-memory fallbacks
#    - No need to install/configure Redis on cPanel
#
# 7. MIGRATIONS:
#    - Migrations run automatically on startup
#    - First deployment may take a few minutes
#    - Subsequent deployments are faster
# ============================================================
