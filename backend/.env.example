# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/easybox_dev

# Server Configuration
PORT=4000
NODE_ENV=development

# File Uploads (defaults to ./uploads in cwd)
UPLOADS_DIR=./uploads

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# JWT Secrets (use strong secrets in production)
JWT_SECRET=dev-secret-change-in-production
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production

# Easybox API Integration
EASYBOX_API_KEY=your-easybox-api-key
EASYBOX_WEBHOOK_SECRET=your-easybox-webhook-secret-min-32-chars

# Logging Level
LOG_LEVEL=debug

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
