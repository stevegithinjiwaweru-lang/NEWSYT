# ─────────────────────────────────────────────────────────────────────────────
# Easybox backend (NEWSYT) — environment
# Copy to .env and fill values. NEVER commit a populated .env.
# Validated at startup by src/config/env.ts (zod).
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres — matches docker-compose service
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/easybox?schema=public

# Redis — matches docker-compose service
REDIS_URL=redis://localhost:6379

# JWT — internal dashboard/rider auth. Both must be ≥32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-a-32-plus-char-random-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-32-plus-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# External API — pepper applied to API-key hashing before bcrypt. ≥32 chars.
# Treat as a master secret; rotating it invalidates every issued API key.
API_KEY_PEPPER=replace-me-with-a-32-plus-char-pepper-value

# Outbound webhooks (Phase 1)
WEBHOOK_MAX_ATTEMPTS=10
WEBHOOK_BASE_BACKOFF_MS=5000

# External API rate limit (per API key, sliding window)
EXTERNAL_RATE_LIMIT_WINDOW_MS=60000
EXTERNAL_RATE_LIMIT_MAX=60

# Customer-facing tracking page (base URL — dispatch id appended)
EXTERNAL_TRACKING_BASE_URL=http://localhost:5173/track

# Phase 4 — flat fallback cancellation fee when drop-off doesn't fall in any
# Phase 3 zone (zone-based fee is preferred when available).
CANCEL_FEE_FALLBACK_AMOUNT=200
CANCEL_FEE_FALLBACK_CURRENCY=KES

# CORS — comma-separated origins for the internal/dashboard API.
# External /api/v1/external/* is server-to-server and ignores this.
ALLOWED_ORIGINS=http://localhost:5173

# Uploads (POD images, CSV imports)
# UPLOADS_DIR=/usr/src/app/uploads
