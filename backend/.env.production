# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/easybox_db

# Server Configuration
PORT=4000
NODE_ENV=production

# File Uploads
UPLOADS_DIR=/app/uploads

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_SECRET=your-secure-jwt-secret-change-this
REFRESH_TOKEN_SECRET=your-secure-refresh-token-change-this

# Sentry/Error Tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# Logging Level
LOG_LEVEL=info