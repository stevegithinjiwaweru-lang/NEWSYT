generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  phone         String         @unique
  email         String?        @unique
  passwordHash  String
  role          UserRole       @default(DISPATCHER)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  rider         Rider?
  refreshTokens RefreshToken[]
}

model Rider {
  id            String       @id @default(cuid())
  userId        String?      @unique

  name          String
  phone         String
  nationalId    String?
  bikeReg       String?
  branch        String?

  status        RiderStatus  @default(AVAILABLE)

  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders        Order[]
}

model Merchant {
  id            String          @id @default(cuid())

  name          String          @unique

  connector     ConnectorType

  status        MerchantStatus  @default(CONNECTED)

  config        Json?

  lastSyncAt    DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  orders        Order[]
}

model Order {
  id             String        @id @default(cuid())

  externalId     String?       @unique

  merchantId     String
  riderId        String?

  customerName   String
  phone          String
  address        String

  lat            Float?
  lng            Float?

  amount         Float

  paymentType    PaymentType   @default(COD)

  status         OrderStatus   @default(NEW)

  attemptCount   Int           @default(0)

  podUrl         String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  merchant       Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rider          Rider?        @relation(fields: [riderId], references: [id], onDelete: SetNull)

  // ----- Pick & Drop extensions (additive, nullable) -----
  orderType      OrderType?    @default(STANDARD)
  customerId     String?
  pickupLat      Float?
  pickupLng      Float?
  dropoffLat     Float?
  dropoffLng     Float?
  distanceKm     Float?
  estimatedFare  Float?
  actualFare     Float?
  promoCodeId    String?
  timeline       Json?
}

model RefreshToken {
  id          String      @id @default(cuid())

  token       String      @unique

  userId      String?
  customerId  String?

  expiresAt   DateTime

  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  DISPATCHER
  RIDER
}

enum RiderStatus {
  AVAILABLE
  BUSY
  IN_DELIVERY
  OFFLINE
  SUSPENDED
}

enum MerchantStatus {
  CONNECTED
  DISCONNECTED
}

enum ConnectorType {
  CSV
  API
  APP
}

enum PaymentType {
  COD
  PREPAID
}

enum OrderStatus {
  NEW
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

// -------------------- New enums and models for EasyBox V2 --------------------

enum OrderType {
  ENTERPRISE
  PICK_DROP
  STANDARD
}

enum PaymentMethod {
  MPESA
  CASH
  CORPORATE
  WALLET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Customer {
  id           String    @id @default(cuid())
  userId       String?   @unique
  firstName    String?
  lastName     String?
  email        String?   @unique
  phone        String?   @unique
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  addresses    SavedAddress[]
  orders       Order[]   @relation("customer_orders")
  wallet       Wallet?
  ratings      Rating[]
}

model SavedAddress {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  label      String?
  address    String
  lat        Float
  lng        Float
  createdAt  DateTime @default(now())
}

model Vehicle {
  id          String   @id @default(cuid())
  type        String   // MOTORCYCLE, TUKTUK, PICKUP, VAN
  plateNumber String?
  capacity    Int?
  createdAt   DateTime @default(now())
}

model Trip {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  riderId     String?
  startAt     DateTime?
  endAt       DateTime?
  distanceKm  Float?
  durationMin Int?
  events      Json?    // timeline of events
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String?
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  method          PaymentMethod
  amount          Float
  status          PaymentStatus @default(PENDING)
  transactionRef  String?
  callbackMeta    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Wallet {
  id           String    @id @default(cuid())
  ownerType    String    // "CUSTOMER" | "RIDER" | "DRIVER"
  ownerId      String
  balance      Float     @default(0)
  currency     String    @default("KES")
  transactions WalletTransaction[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Float
  type        String   // CREDIT | DEBIT
  meta        Json?
  createdAt   DateTime @default(now())
}

model PricingRule {
  id            String   @id @default(cuid())
  name          String
  baseFare      Float
  perKm         Float
  perMinute     Float
  vehicleType   String?  // MOTORCYCLE, TUKTUK, PICKUP, VAN
  packageSize   String?  // SMALL, MEDIUM, LARGE, FRAGILE, FOOD, ELECTRONICS
  isSurgeActive Boolean  @default(false)
  multiplier    Float    @default(1.0)
  conditions    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   // PERCENT | FIXED
  amount        Float
  active        Boolean  @default(true)
  usageLimit    Int?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  recipient  String   // user id / customer id / rider id
  channel    String   // PUSH | SMS | EMAIL | SOCKET
  title      String?
  body       String?
  meta       Json?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Rating {
  id         String   @id @default(cuid())
  raterId    String
  ratedId    String
  score      Int
  comment    String?
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model SupportTicket {
  id          String   @id @default(cuid())
  customerId  String?
  subject     String
  message     String
  status      String   @default("OPEN")
  assigneeId  String?
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
