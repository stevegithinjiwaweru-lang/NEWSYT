generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  phone         String         @unique
  email         String?        @unique
  passwordHash  String
  role          UserRole       @default(DISPATCHER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  rider         Rider?
}

model Rider {
  id         String      @id @default(cuid())
  name       String
  phone      String
  nationalId String?
  bikeReg    String?
  branch     String?
  status     RiderStatus @default(AVAILABLE)
  lastLat    Float?
  lastLng    Float?
  lastSeenAt DateTime?
  userId     String?     @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orders     Order[]
  user       User?       @relation(fields: [userId], references: [id])
}

model Merchant {
  id               String            @id @default(cuid())
  name             String
  connector        ConnectorType
  status           MerchantStatus    @default(CONNECTED)
  config           Json?
  lastSyncAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  orders           Order[]
  idempotencyKeys  IdempotencyKey[]
  outboundWebhooks OutboundWebhook[]
}

model Order {
  id              String         @id @default(cuid())
  externalId      String?
  merchantId      String
  customerName    String
  phone           String
  address         String
  lat             Float?
  lng             Float?
  pickupAddress   String?
  pickupLat       Float?
  pickupLng       Float?
  packageNotes    String?
  etaMinutes      Int?
  amount          Float
  paymentType     PaymentType    @default(COD)
  paymentStatus   PaymentStatus  @default(NOT_REQUIRED)
  paymentMethod   PaymentMethod?
  amountCollected Float?
  paymentRef      String?
  paidAt          DateTime?
  status          OrderStatus    @default(NEW)
  riderId         String?
  attemptCount    Int            @default(0)
  podUrl          String?
  cancelledAt     DateTime?
  cancelReason    String?
  cancelFee       Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  merchant        Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rider           Rider?         @relation(fields: [riderId], references: [id])

  @@unique([merchantId, externalId])
  @@index([status])
  @@index([riderId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  merchantId   String
  key          String
  requestHash  String
  statusCode   Int
  responseBody Json
  createdAt    DateTime @default(now())
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, key])
  @@index([createdAt])
}

model Zone {
  id              String   @id @default(cuid())
  name            String
  polygonGeoJson  Json
  baseFee         Float
  perKmFee        Float?
  currency        String   @default("KES")
  operatingHours  Json
  dailyCutoff     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
  @@index([name])
}

model OutboundWebhook {
  id          String                @id @default(cuid())
  merchantId  String
  eventId     String                @unique
  event       String
  payload     Json
  targetUrl   String
  status      WebhookDeliveryStatus @default(PENDING)
  attempts    Int                   @default(0)
  lastError   String?
  deliveredAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  merchant    Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, createdAt])
  @@index([status, attempts])
}

enum UserRole {
  ADMIN
  DISPATCHER
  RIDER
}

enum RiderStatus {
  AVAILABLE
  BUSY
  OFFLINE
  SUSPENDED
  IN_DELIVERY
}

enum ConnectorType {
  CSV
  API
  APP
}

enum MerchantStatus {
  CONNECTED
  DISCONNECTED
}

enum PaymentType {
  COD
  PREPAID
}

enum PaymentStatus {
  PENDING
  COLLECTED
  FAILED
  NOT_REQUIRED
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
}

enum OrderStatus {
  NEW
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}
