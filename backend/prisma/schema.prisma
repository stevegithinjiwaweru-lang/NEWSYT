generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid()) @map("_id")
  name          String
  phone         String         @unique
  email         String?
  passwordHash  String
  role          UserRole       @default(DISPATCHER)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  rider         Rider?
  refreshTokens RefreshToken[]

  @@index([email])
}

model Rider {
  id            String       @id @default(cuid()) @map("_id")
  userId        String?      @unique

  name          String
  phone         String
  nationalId    String?
  bikeReg       String?
  branch        String?
  
  vehicleType   String?      // e.g., "motorcycle", "van", "bicycle"
  vehiclePlate  String?

  status        RiderStatus  @default(AVAILABLE)

  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders        Order[]
  dispatches    Dispatch[]
}

model Merchant {
  id            String          @id @default(cuid()) @map("_id")

  name          String          @unique

  connector     ConnectorType

  status        MerchantStatus  @default(CONNECTED)

  config        Json?

  lastSyncAt    DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  orders        Order[]
}

model Order {
  id             String        @id @default(cuid()) @map("_id")

  externalId     String?

  merchantId     String
  riderId        String?

  customerName   String
  phone          String
  address        String

  lat            Float?
  lng            Float?

  amount         Float

  paymentType    PaymentType   @default(COD)

  status         OrderStatus   @default(NEW)

  attemptCount   Int           @default(0)

  podUrl         String?
  
  // Dispatch relationship
  dispatch       Dispatch?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  merchant       Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  rider          Rider?        @relation(fields: [riderId], references: [id], onDelete: SetNull)

  @@index([externalId])
}

model Dispatch {
  id             String         @id @default(cuid()) @map("_id")
  
  // Easybox dispatch ID (returned from Easybox API)
  easyboxId      String?
  
  // Order reference (Zucchini order ID)
  orderReference String         @unique
  orderId        String?        @unique
  
  // Dispatch status lifecycle
  status         DispatchStatus @default(PENDING)
  
  // Rider assignment
  riderId        String?
  
  // Location info
  pickupLat      Float?
  pickupLng      Float?
  deliveryLat    Float?
  deliveryLng    Float?
  
  // Timing estimates
  estimatedPickup    DateTime?
  estimatedDelivery  DateTime?
  actualPickupAt     DateTime?
  actualDeliveryAt   DateTime?
  
  // Payment on delivery
  podEnabled     Boolean        @default(false)
  podAmount      Float?
  podCurrency    String?        @default("KES")
  podCollected   Boolean        @default(false)
  podMethod      String?        // e.g., "mpesa", "cash"
  podReference   String?
  
  // Package details
  packageDescription String?
  packageWeight  Float?
  packageValue   Float?
  
  // Failure/cancellation reason
  failureReason  String?
  cancellationReason String?
  
  // Tracking/event log
  events         DispatchEvent[]
  
  // Metadata
  metadata       Json?
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  rider          Rider?         @relation(fields: [riderId], references: [id], onDelete: SetNull)
  
  @@index([status])
  @@index([easyboxId])
}

model DispatchEvent {
  id             String         @id @default(cuid()) @map("_id")
  
  dispatchId     String
  
  // Event type: created, assigned, picked_up, en_route, arrived, delivered, failed, cancelled
  event          String
  
  // Event status (maps to dispatch status)
  status         DispatchStatus?
  
  // Location (if applicable)
  lat            Float?
  lng            Float?
  accuracy       Float?
  
  // Failure/reason (if applicable)
  reason         String?
  
  // Rider info snapshot
  riderName      String?
  riderPhone     String?
  
  // Event timestamp from Easybox
  eventTimestamp DateTime?
  
  // Server timestamp
  createdAt      DateTime       @default(now())
  
  dispatch       Dispatch       @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  
  @@index([dispatchId])
  @@index([event])
}

model RefreshToken {
  id          String      @id @default(cuid()) @map("_id")

  token       String      @unique

  userId      String

  expiresAt   DateTime

  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  DISPATCHER
  RIDER
}

enum RiderStatus {
  AVAILABLE
  BUSY
  IN_DELIVERY
  OFFLINE
  SUSPENDED
}

enum MerchantStatus {
  CONNECTED
  DISCONNECTED
}

enum ConnectorType {
  CSV
  API
  APP
}

enum PaymentType {
  COD
  PREPAID
}

enum OrderStatus {
  NEW
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum DispatchStatus {
  PENDING
  CREATED
  ASSIGNED
  PICKED_UP
  EN_ROUTE
  ARRIVED
  DELIVERED
  FAILED
  CANCELLED
}
