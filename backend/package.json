{
  "name": "easybox-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Easybox Logistics backend system",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "typecheck": "tsc -p . --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "seed": "ts-node --transpile-only prisma/seed.ts",
    "worker": "ts-node --transpile-only src/jobs/worker.ts",
    "worker:webhooks": "ts-node --transpile-only src/modules/external/webhooks/delivery.worker.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@turf/boolean-point-in-polygon": "^6.5.0",
    "@turf/helpers": "^6.5.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "bullmq": "^1.91.1",
    "cors": "^2.8.6",
    "csv-parse": "^5.4.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.4.1",
    "fast-csv": "^4.3.6",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prisma": "^6.19.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.1",
    "pino-pretty": "^11.3.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
