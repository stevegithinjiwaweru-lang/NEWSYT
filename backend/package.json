{
  "name": "easybox-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Easybox Logistics backend system",
  "main": "index.js",
  "type": "commonjs",

  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",

    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",

    "seed": "ts-node --transpile-only prisma/seed.ts",

    "worker": "ts-node --transpile-only src/jobs/worker.ts"
  },

  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },

  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "bullmq": "^1.91.1",
    "cors": "^2.8.6",
    "csv-parse": "^5.4.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "fast-csv": "^4.3.6",
    "ioredis": "^5.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.19.3",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3"
  },

  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}