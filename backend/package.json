{
  "name": "easybox-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Easybox Logistics backend system",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p . && npm run prisma:generate",
    "start": "node dist/index.js",
    "prestart": "npm run prisma:generate && npm run db:deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push",
    "db:deploy": "prisma db push",
    "seed": "ts-node --transpile-only prisma/seed.ts",
    "verify:build": "npm run build && node -c dist/index.js"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.18.1",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "csv-parse": "^5.4.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "fast-csv": "^4.3.6",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
